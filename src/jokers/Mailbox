SMODS.Joker {
    key = 'mailbox',
    atlas = 'placeholders',
    pos = { x = 0, y = 0 },

    rarity = 1,
    cost = 4,

    config = {
        extra = {
            mult = 7,
            transformed = false,
            at_zero = false,
            processed = false
        }
    },

    loc_vars = function(self, info_queue, card)

        if card.ability.extra.transformed then
            return {
                vars = { 13 }
            }
        else
            return {
                vars = { card.ability.extra.mult }
            }
        end
    end,

    calculate = function(self, card, context)

        if context.joker_main then
            return {
                mult = card.ability.extra.mult
            }
        end

        if context.setting_blind then
            card.ability.extra.processed = false
        end

        if context.end_of_round and not card.ability.extra.processed and not context.blueprint then

            card.ability.extra.processed = true

            if card.ability.extra.transformed then
                return
            end

            if not card.ability.extra.at_zero then
                card.ability.extra.mult = card.ability.extra.mult - 1

                if card.ability.extra.mult <= 0 then
                    card.ability.extra.mult = 0
                    card.ability.extra.at_zero = true
                end

                return {
                    message = "-1 Mult",
                    colour = G.C.MULT
                }
            end

            if card.ability.extra.at_zero then
                card.ability.extra.mult = 13
                card.ability.extra.transformed = true

                return {
                    message = "You've got mail!",
                    colour = G.C.GREEN,
                    delay = 1
                }
            end
        end
    end
}