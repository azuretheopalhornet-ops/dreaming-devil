SMODS.Joker {
    key = 'one',
    atlas = 'placeholders',
    blueprint_compat = false,
    rarity = 2,
    cost = 4,
    pos = {
        x = 1,
        y = 0
    },
    calculate = function(self, card, context)
        if context.mod_probability and not context.blueprint then
            return {
                denominator = context.denominator * 2
            }
        end
    end
}