SMODS.Joker {
    key = 'Whisper',
    atlas = 'placeholders',
    pos = {
        x = 1,
        y = 0
    },
    config = {
        extra = {
            chips = 50,
            deduction = 1
        }
    },
    rarity = 1,
    cost = 3,

    loc_vars = function(self, info_queue, card)
        return {
            vars = {
                card.ability.extra.chips,
                card.ability.extra.deduction
            }
        }
    end,

    calculate = function(self, card, context)
        if context.joker_main then
            return {
                chips = card.ability.extra.chips
            }
        end
    end,

        add_to_deck = function(self, card)
        G.E_MANAGER:add_event(Event({
            func = function()
                G.GAME.round_resets.reroll_cost = G.GAME.round_resets.reroll_cost - card.ability.extra.deduction
                G.GAME.current_round.reroll_cost = math.max(0,
                    G.GAME.current_round.reroll_cost - card.ability.extra.deduction)
                return true
            end
        }))
    end,

    remove_from_deck = function(self, card)
        G.E_MANAGER:add_event(Event({
            func = function()
                G.GAME.round_resets.reroll_cost = G.GAME.round_resets.reroll_cost + card.ability.extra.deduction
                G.GAME.current_round.reroll_cost = math.max(0,
                    G.GAME.current_round.reroll_cost + card.ability.extra.deduction)
                return true
            end
        }))
    end,
}