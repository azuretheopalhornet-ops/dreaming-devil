-- ==========================================
-- 0.5. UI INTERCEPTOR (THE TEXT COLOR FIX)
-- ==========================================
-- We intercept Balatro's badge creation to force our custom text color
local original_create_badge = create_badge
function create_badge(text, bg_col, text_col, scale)
    -- If the game is trying to draw our specific rarity badge...
    if type(text) == 'string' and text == "Legendary V.I.P." then
        -- Force the text color to our custom Golden Yellow!
        text_col = G.C.KYUBEY_GOLDEN_YELLOW
    end
    -- Proceed with normal badge creation using our modified colors
    return original_create_badge(text, bg_col, text_col, scale)
end

-- ==========================================
-- 1. KIN JOKER (Appears in Shop)
-- ==========================================
SMODS.Joker {
    key = 'kin',
    atlas = 'placeholders',
    pos = { x = 0, y = 0 },
    rarity = 2, -- Uncommon
    cost = 6,
    unlocked = true,
    discovered = true,
    blueprint_compat = true,

    -- This adds the Hot Pink "Fusion" tag to the card
    set_badges = function(self, card, badges)
        badges[#badges + 1] = create_badge("Fusion", G.C.KYUBEY_HOT_PINK, G.C.WHITE, 1.2)
    end,
    
    calculate = function(self, card, context)
        if context.joker_main then
            return {
                mult_mod = 12,
                message = '+12 Mult',
                card = card
            }
        end
        
        if context.before and not context.blueprint then
            for i = 1, #context.scoring_hand do
                local played_card = context.scoring_hand[i]
                if not played_card.set_seal then
                    played_card:set_seal('Gold', nil, true)
                end
            end
        end
    end
}

