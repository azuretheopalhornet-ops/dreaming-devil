SMODS.Joker {
    key = 'paracetamol',
    atlas = 'placeholders',
    pos = { x = 0, y = 0 },

    rarity = 2,
    cost = 4,

    config = {
        extra = {
            mult = 15,
            mult_loss = 2
        }
    },

    loc_vars = function(self, info_queue, card)
        return {
            vars = {
                card.ability.extra.mult,
                card.ability.extra.mult_loss
            }
        }
    end,

    calculate = function(self, card, context)

        -- main effect
        if context.joker_main then
            return {
                mult = card.ability.extra.mult
            }
        end

        -- lose mult per hand
        if context.after and not context.blueprint then
            card.ability.extra.mult = math.max(0, card.ability.extra.mult - card.ability.extra.mult_loss)

            return {
                message = "-" .. card.ability.extra.mult_loss .. " Mult",
                colour = G.C.MULT
            }
        end

        -- reset at end of round (FLASH STYLE)
        if context.end_of_round and not context.blueprint then

            local changed = (card.ability.extra.mult ~= 15)

            card.ability.extra.mult = 15

            if changed then
                return {
                    message = "RESET!",
                    colour = G.C.GREEN
                }
            end
        end
    end
}